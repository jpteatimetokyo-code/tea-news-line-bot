# Copy this file to .env and fill in your values for local testing.
# (main.py reads these from the process environment; use `set -a; source .env; set +a`
#  or a tool like `python-dotenv` / `direnv` to load this file before running.)

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_USER_ID=your-line-user-id

# Optional overrides
CLAUDE_MODEL=claude-opus-4-8
